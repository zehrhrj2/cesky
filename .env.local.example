# ============================================================
# ČESKY App — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# ---- GROQ API (Required for AI Chat) ----
# Get your key at: https://console.groq.com
NEXT_PUBLIC_GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# ---- Supabase (Optional - for cloud sync & auth) ----
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
